# ── 대회 데이터 (용량/라이선스 문제로 git에 올리지 않음) ──
data/*
!data/.gitkeep

# ── 모델 가중치 (용량 큼, GitHub 파일당 100MB 제한) ──
*.pt
*.pth
*.bin
*.safetensors
*.ckpt
*.pkl
*.joblib
*.onnx
submit/model/*
!submit/model/.gitkeep

# ── 제출 압축 파일 ──
*.zip

# ── 추론 출력 ──
output/

# ── Python ──
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/
env/

# ── OS / IDE / 에디터 백업 ──
.DS_Store
Thumbs.db
.idea/
.vscode/
*~
